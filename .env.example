# Cinelog local development example
# Copy this file to .env and fill locally.
# Never commit .env.

SPRING_PROFILES_ACTIVE=local

CINELOG_DB_HOST=localhost
CINELOG_DB_PORT=3306
CINELOG_DB_NAME=cinelog
CINELOG_DB_USERNAME=cinelog
CINELOG_DB_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:mariadb://localhost:3306/cinelog
SPRING_DATASOURCE_USERNAME=cinelog
SPRING_DATASOURCE_PASSWORD=change-me

CINELOG_ADMIN_USERNAME=admin
CINELOG_ADMIN_PASSWORD=change-me
CINELOG_ADMIN_DISPLAY_NAME=Thomas

CINELOG_REMEMBER_ME_KEY=change-me-generate-with-openssl-rand-base64-64
TMDB_API_KEY=change-me
